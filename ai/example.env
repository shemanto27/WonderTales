# ─────────────────────────────────────────────
#  WonderTels Hub  –  Environment Variables
# ─────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=
OPENAI_MAX_TOKENS=1500
OPENAI_TEMPERATURE=0.85

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1

# ── Narration Voices (3-tier structure for 2–9 years) ────────────────────────
# Primary Soothing: Main narrator – most calming & bedtime-friendly
ELEVENLABS_VOICE_PRIMARY_FEMALE=XB0fDUnXU5powFXDhCwa    # Charlotte
ELEVENLABS_VOICE_PRIMARY_MALE=onwK4e9ZLuTAKqWW03F9       # Daniel
# Secondary Softer: Backup narrator – alternative & character voices
ELEVENLABS_VOICE_SECONDARY_FEMALE=21m00Tcm4TlvDq8ikWAM   # Rachel
ELEVENLABS_VOICE_SECONDARY_MALE=TX3LPaxmHKxFdv7VOQHJ      # Liam
# Child Dialogue: Character & dialogue voices (use sparingly)
ELEVENLABS_VOICE_CHILD_FEMALE=XrExE9yKIg1WjnnlVkGX       # Matilda
ELEVENLABS_VOICE_CHILD_MALE=JBFqnCBsd6RMkjVDRZzb         # George

# App
APP_ENV=production
APP_SECRET_KEY=change-me-to-a-long-random-secret
APP_HOST=0.0.0.0
APP_PORT=8050
LAN_HOST=10.10.20.77
TAILSCALE_HOST=100.81.104.38
TAILSCALE_PATH=/app
AUDIO_STORAGE_DIR=./audio_files
MAX_VOICE_RECORDING_SECONDS=120
ALLOWED_ORIGINS=https://your-frontend.com
